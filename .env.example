# ── Used when latest.json is not available (standalone Vercel deploy) ────────
# Set VITE_OVERRIDE_CONTRACTS=true and define each address below
VITE_OVERRIDE_CONTRACTS=false

VITE_SHIELD_VAULT=0x...
VITE_TIMELOCK=0x...
VITE_GOVERNANCE=0x...
VITE_STAKING=0x...
VITE_NULLIFIER_REGISTRY=0x...
VITE_MERKLE_TREE_MANAGER=0x...
VITE_DEPOSIT_MANAGER=0x...
VITE_WITHDRAWAL_MANAGER=0x...
VITE_SHIELDED_TRANSFER=0x...
VITE_PRIVATE_SWAP=0x...
VITE_PRIVATE_BRIDGE=0x...
VITE_EMERGENCY_CONTROLLER=0x...
VITE_VERIFIER_ZK=0x...

# MockDEXRouter — deployed by setup-swap.js (testnet only)
VITE_MOCK_DEX_ROUTER=0x...

# Circle App Kit key (free — https://console.circle.com)
VITE_KIT_KEY=your_kit_key_here
